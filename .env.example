# --- Security Configuration ---
# Current version of the blind index pepper to use
Security__CurrentVersion=1

# Blind Index Peppers (Hex-64 or Hex-128 strings)
# Generate unique long random strings for each version
Security__BlindIndexPeppers__1="your_very_long_random_hex_string_here_v1"
Security__BlindIndexPeppers__2="your_very_long_random_hex_string_here_v2"
Security__BlindIndexPeppers__3=""
Security__BlindIndexPeppers__4=""
Security__BlindIndexPeppers__5=""
Security__BlindIndexPeppers__6=""
Security__BlindIndexPeppers__7=""

# SMTP Password for Email Sending (Encrypted or Plain, depending on your provider)
Security__SmtpPassword="your_smtp_password_here"

# JWT Configuration (Format: issuer;audience)
Security__IssuerAudiencePair="api.yourdomain.com;frontend.yourdomain.com"

# Security Keys (Base64 encoded keys)
# Generate with: openssl rand -base64 32
Security__Keys__AesKey="base64_encoded_32_byte_key_here="
Security__Keys__JwtSigningKey="base64_encoded_32_byte_key_here="
Security__Keys__HmacSecretKey="base64_encoded_32_byte_key_here="

# Initial Administrator Credentials
Security__AdminUsername="Admin"
Security__AdminPassword="ChangeMe123!"

# --- Email Configuration (for local Mailhog testing) ---
Email__Address="noreply@yourdomain.com"
Email__Host="localhost"
Email__Port=1025

# --- Database Configuration ---
Database__User="postgres"
Database__Password="password"
Database__Name="your_db_name"
Database__ApiUrl="https://localhost:5001/api"
Database__Host="Host=localhost;Port=5432;Database=your_db_name;Username=postgres;Password=password"

# --- Frontend Configuration ---
FrontendUrl="http://localhost:5173"

# --- CORS Configuration ---
# Comma separated list of allowed origins
Cors__AllowedOrigins="http://localhost:5173"